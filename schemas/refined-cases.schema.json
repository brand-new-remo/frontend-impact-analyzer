{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontend-impact-analyzer.local/schemas/refined-cases.schema.json",
  "title": "Frontend Impact Analyzer Refined Cases",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "meta",
    "summary",
    "cases",
    "refinementNotes",
    "guardrails"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["outputContract", "sourceResult", "refinementStatus"],
      "properties": {
        "outputContract": {"type": "string", "const": "refined-cases-v1"},
        "sourceResult": {"type": "string"},
        "runId": {"type": ["string", "null"]},
        "refinementStatus": {
          "type": "string",
          "enum": ["success", "partial_success", "blocked"]
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "originalCaseCount",
        "refinedCaseCount",
        "removedCaseCount",
        "mergedCaseCount",
        "splitCaseCount"
      ],
      "properties": {
        "originalCaseCount": {"type": "integer", "minimum": 0},
        "refinedCaseCount": {"type": "integer", "minimum": 0},
        "removedCaseCount": {"type": "integer", "minimum": 0},
        "mergedCaseCount": {"type": "integer", "minimum": 0},
        "splitCaseCount": {"type": "integer", "minimum": 0}
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["clusterId", "caseName", "testSteps", "expectedResults", "evidence", "confidence"],
        "properties": {
          "clusterId": {"type": "string"},
          "caseSource": {"type": "string"},
          "moduleName": {"type": "string"},
          "pageName": {"type": "string"},
          "routePath": {"type": "string"},
          "caseName": {"type": "string"},
          "businessGoal": {"type": "string"},
          "entry": {"type": "object"},
          "preconditions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "testSteps": {
            "type": "array",
            "items": {"type": "string"}
          },
          "expectedResults": {
            "type": "array",
            "items": {"type": "string"}
          },
          "priority": {"type": "string"},
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "changeIntent": {"type": "string"},
          "userVisibleChange": {"type": "string"},
          "affectedFunctionUnit": {"type": "string"},
          "impactReason": {"type": "string"},
          "evidence": {
            "type": "array",
            "items": {"type": "object"}
          },
          "uncertainties": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "refinementNotes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "reason"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["wording", "removed", "merged", "split", "reordered", "unchanged"]
          },
          "clusterId": {"type": "string"},
          "caseName": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "scopeExpanded",
        "confidenceUpgraded",
        "unsupportedExpectationsAdded"
      ],
      "properties": {
        "scopeExpanded": {"type": "boolean", "const": false},
        "confidenceUpgraded": {"type": "boolean", "const": false},
        "unsupportedExpectationsAdded": {"type": "boolean", "const": false}
      }
    }
  }
}
